# ═══════════════════════════════════════════════════════════════════════
# Sparki Dashboarding Platform — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in real values for local development.
# NEVER commit the actual `.env` file. In production, use a secrets vault.

# ─── General ──────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | staging | production
TZ=Europe/Brussels

# ─── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sparki
POSTGRES_USER=sparki
POSTGRES_PASSWORD=changeme-postgres-password

# ─── InfluxDB ─────────────────────────────────────────────────────────
INFLUXDB_HOST=influxdb
INFLUXDB_PORT=8086
INFLUXDB_ORG=sparki
INFLUXDB_BUCKET=energy
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme-influx-admin
# Generated after first boot; paste here once obtained from Influx UI / init
INFLUXDB_TOKEN=changeme-influx-token

# ─── Keycloak ─────────────────────────────────────────────────────────
KEYCLOAK_HOST=keycloak
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme-keycloak-admin
KEYCLOAK_REALM=sparki
KEYCLOAK_CLIENT_ID=webapp
KEYCLOAK_CLIENT_SECRET=changeme-webapp-client-secret
# URL used by browser (external) — typically via Caddy
KEYCLOAK_PUBLIC_URL=http://localhost:8080
# URL used by webapp container (internal docker network)
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# ─── FastAPI Webapp ───────────────────────────────────────────────────
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8000
# Used to sign session cookies and CSRF tokens
WEBAPP_SECRET_KEY=changeme-generate-a-long-random-string
# Used by core/security.py to encrypt Sigencloud credentials at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=changeme-generate-with-fernet

# ─── Sigencloud API (filled in when access granted) ───────────────────
# EU regional endpoint. Sigencloud has separate endpoints per region.
# Use https://api-cn.sigencloud.com if your stations are in China.
SIGENCLOUD_BASE_URL=https://api-eu.sigencloud.com
# Sigencloud RATE LIMIT: energyFlow endpoint is capped at 1 request per
# 5 minutes per station (third-party accounts). General API calls are
# limited to 10 requests/minute. We pick 300s to stay safely within.
SIGENCLOUD_POLL_INTERVAL_SECONDS=300
# Per-organization credentials live in the database (encrypted), not here.

# ─── ENTSO-E ──────────────────────────────────────────────────────────
ENTSOE_API_TOKEN=changeme-entsoe-token
ENTSOE_BIDDING_ZONE=10YBE----------2   # Belgium

# ─── Node-RED ─────────────────────────────────────────────────────────
# Admin UI credentials. Generate the bcrypt hash with:
#   docker run --rm nodered/node-red:latest npx -y node-red-admin hash-pw
NODERED_ADMIN_USER=admin
NODERED_ADMIN_PASSWORD_HASH=changeme-bcrypt-hash
# UI toggle: "true" enables the visual editor (dev), "false" runs headless (prod).
NODERED_UI_ENABLED=true

# ─── Caddy ────────────────────────────────────────────────────────────
# In production, set to your real domain. Caddy will auto-fetch Let's Encrypt cert.
CADDY_DOMAIN=localhost

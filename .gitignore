# ─── Secrets & local config ───────────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem

# ─── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ─── uv ───────────────────────────────────────────────────────────────
# uv.lock IS committed (reproducible builds)
# but cache directory is not
.uv-cache/

# ─── Docker runtime data ──────────────────────────────────────────────
# Volume-mounted data should never be committed
postgres-data/
influxdb-data/
influxdb-config-data/
keycloak-data/
node-red-data/
caddy-data/
caddy-config/

# ─── IDE / Editor ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Build artifacts ──────────────────────────────────────────────────
dist/
build/
*.log

# ─── Backups (local) ──────────────────────────────────────────────────
backups/
*.dump
*.sql.gz
